{
  "manifest_version": 3,
  "name": "Instagram Viewer Search",
  "version": "1.0",
  "description": "Search Instagram story viewers",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"]
    }
  ]
}